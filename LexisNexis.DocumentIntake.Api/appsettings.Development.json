{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AWS": {
    "ServiceURL": "http://localhost:4566",
    "BucketName": "documents-local",
    "Region": "us-east-1",
    "ForcePathStyle": true
  },
  "Security": {
    "ApiKey": "dev-api-key-change-in-prod"
  },
  "RateLimiting": {
    "PermitLimit": 30,
    "WindowMinutes": 1
  },
  "Processing": {
    "MaxPreviewLength": 500,
    "WorkerDelayMs": 500
  }
}
